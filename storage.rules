rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCoach() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['coach', 'collaborator', 'admin'];
    }

    function isRegisteredStudent() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    match /progress_videos/{userId}/{videoId}/{fileName} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isCoach());
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
      allow delete: if isCoach() || (isSignedIn() && request.auth.uid == userId);
    }

    match /tribe/{postId}/{fileName} {
      allow read: if true;
      allow write: if isRegisteredStudent()
        && request.resource.size < 100 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|video/.*');
    }

    function hasUserProfile() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    match /marketplace/{listingId}/{fileName} {
      allow read: if true;
      allow write: if hasUserProfile()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if hasUserProfile();
    }

    match /invoices/{bookingId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isCoach()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
