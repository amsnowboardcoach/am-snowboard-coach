rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isCoach() {
      return isSignedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['coach', 'collaborator', 'admin'];
    }

    function isAlumnoRoleValue(role) {
      return role == 'alumno' || role == 'student';
    }

    function isRegisteredStudent() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && isAlumnoRoleValue(
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        );
    }

    match /progress_videos/{userId}/{videoId}/{fileName} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isCoach());
      allow write: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
      allow delete: if isCoach() || (isSignedIn() && request.auth.uid == userId);
    }

    function tribeMediaContentTypeOk(name) {
      return request.resource.contentType.matches('image/.*|video/.*')
        || name.matches('.*\\.(?i)(jpg|jpeg|png|webp|heic|heif|gif|mp4|mov|m4v|webm)$');
    }

    match /tribe/{postId}/{fileName} {
      allow read: if true;
      allow write: if isRegisteredStudent()
        && request.resource.size < 100 * 1024 * 1024
        && tribeMediaContentTypeOk(fileName);
    }

    function hasUserProfile() {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function marketplaceListingSeller(listingId) {
      return firestore.get(/databases/(default)/documents/marketplace_listings/$(listingId)).data.sellerId;
    }

    function canWriteMarketplaceFiles(listingId) {
      return !firestore.exists(/databases/(default)/documents/marketplace_listings/$(listingId))
        || marketplaceListingSeller(listingId) == request.auth.uid;
    }

    function canDeleteMarketplaceFiles(listingId) {
      return !firestore.exists(/databases/(default)/documents/marketplace_listings/$(listingId))
        || marketplaceListingSeller(listingId) == request.auth.uid
        || isCoach();
    }

    match /marketplace/{listingId}/{fileName} {
      allow read: if true;
      allow write: if hasUserProfile()
        && canWriteMarketplaceFiles(listingId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if hasUserProfile() && canDeleteMarketplaceFiles(listingId);
    }

    match /invoices/{bookingId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isCoach()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
