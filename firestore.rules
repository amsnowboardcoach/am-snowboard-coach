rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isCoach() {
      return isSignedIn()
        && userDoc().data.role in ['coach', 'collaborator', 'admin'];
    }

    function isRegisteredStudent() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == 'student';
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function marketplaceListingValidCreate() {
      return request.resource.data.sellerId == request.auth.uid
        && request.resource.data.status == 'active'
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 3
        && request.resource.data.title.size() <= 80
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 10
        && request.resource.data.description.size() <= 2000
        && request.resource.data.priceEuros is int
        && request.resource.data.priceEuros >= 1
        && request.resource.data.priceEuros <= 99999
        && request.resource.data.condition in ['new', 'like_new', 'used']
        && request.resource.data.category in ['tabla', 'fijaciones', 'botas', 'ropa', 'cascos', 'mochilas', 'accesorios', 'otros']
        && request.resource.data.imageUrls is list
        && request.resource.data.imageUrls.size() >= 1
        && request.resource.data.imageUrls.size() <= 5;
    }

    function tribeCommentValidCreate() {
      return request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 500
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() >= 1
        && request.resource.data.authorDisplayName.size() <= 40;
    }

    function tribeCountsOnlyUpdate() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['fireCount'])
        || changed.hasOnly(['commentCount']);
    }

    function isCoachSignupEmail() {
      return request.auth.token.email == 'amsnowboardcoach@gmail.com';
    }

    function userCreateValid(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && (
          request.resource.data.role == 'student'
          || (
            request.resource.data.role == 'coach'
            && isCoachSignupEmail()
          )
        );
    }

    function userSelfUpdateValid() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && changed.hasOnly([
          'displayName',
          'photoURL',
          'phone',
          'level',
          'preferences',
          'updatedAt',
        ]);
    }

    /** Corrige perfil creado como alumno con email de coach (solo rol + updatedAt). */
    function coachEmailRoleFix() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isCoachSignupEmail()
        && resource.data.role == 'student'
        && request.resource.data.role == 'coach'
        && changed.hasOnly(['role', 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isCoach();
      allow create: if isOwner(userId) && userCreateValid(userId);
      allow update: if isCoach()
        || (isOwner(userId) && userSelfUpdateValid())
        || (isOwner(userId) && coachEmailRoleFix());

      match /trick_progress/{trickId} {
        allow read: if isOwner(userId) || isCoach();
        allow write: if isCoach();
      }

      match /progress_videos/{videoId} {
        allow read: if isOwner(userId) || isCoach();
        allow create: if isOwner(userId)
          && request.resource.data.studentId == userId
          && request.resource.data.status == 'pending_review';
        allow update: if isCoach();
        allow delete: if isCoach() || isOwner(userId);
      }

      match /fcm_tokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isCoach());
      allow create: if isCoach()
        && request.resource.data.coachId == request.auth.uid;
      allow update: if isCoach();
      allow delete: if isCoach();
    }

    match /tribe_posts/{postId} {
      allow read: if resource.data.moderationStatus == 'approved'
        || (isSignedIn()
          && (resource.data.authorId == request.auth.uid || isCoach()));
      allow create: if isRegisteredStudent()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.legalConsent == true
        && request.resource.data.fireCount == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.mediaType in ['photo', 'video']
        && request.resource.data.moderationStatus == 'pending';
      allow update: if isCoach()
        || (isSignedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId)
        || (isSignedIn() && tribeCountsOnlyUpdate());
      allow delete: if isSignedIn()
        && (resource.data.authorId == request.auth.uid || isCoach());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && tribeCommentValidCreate();
        allow delete: if isCoach()
          || resource.data.authorId == request.auth.uid;
      }

      match /fires/{userId} {
        allow read: if true;
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    match /marketplace_listings/{listingId} {
      allow read: if resource.data.status == 'active'
        || (isSignedIn()
          && resource.data.sellerId == request.auth.uid)
        || isCoach();
      allow create: if hasUserProfile()
        && marketplaceListingValidCreate();
      allow update: if isCoach()
        || (hasUserProfile()
          && resource.data.sellerId == request.auth.uid
          && resource.data.status == 'active'
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.status == 'active');
      allow delete: if isCoach()
        || (hasUserProfile() && resource.data.sellerId == request.auth.uid);
    }

    match /snow_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isCoach();

      match /contributions/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    match /coach_daily_tips/{tipId} {
      allow read: if true;
      allow write: if isCoach();
    }

    match /tricks_catalog/{trickId} {
      allow read: if isSignedIn();
      allow write: if isCoach();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /system_config/{docId} {
      allow read: if true;
      allow write: if isCoach();
    }
  }
}
