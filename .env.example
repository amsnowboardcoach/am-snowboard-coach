# Firebase (cliente) — Firebase Console → Configuración del proyecto → Tu app web
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Firebase Console → Cloud Messaging → Certificados web (par de claves). Debe ser la clave pública, no vacía.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Pexels — fotos y vídeos en la web (solo servidor, no NEXT_PUBLIC)
PEXELS_API_KEY=

# Firebase Admin (servidor) — Cuenta de servicio → Generar nueva clave privada
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Stripe (pagos en /reservar) — clave secreta sk_live_ o sk_test_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Opcional (Checkout redirect no la requiere)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Calendar — amsnowboardcoach@gmail.com (ver docs/GOOGLE_CALENDAR_EMAIL.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Donde se crean eventos al aceptar reservas AM (primary o email del calendario)
GOOGLE_CALENDAR_ID=primary
# Calendario Explora (Alex): ocupación para /reservar — debe estar compartido con la cuenta OAuth
# ID del calendario compartido (Integrar calendario en Google Calendar)
GOOGLE_EXPLORA_CALENDAR_ID=xxxx@group.calendar.google.com
# Opcional: más calendarios para freeBusy (emails/ids separados por coma)
# GOOGLE_BUSY_CALENDAR_IDS=
# Opcional: duplicar evento al confirmar (por defecto usa GOOGLE_EXPLORA_CALENDAR_ID si está definido)
# GOOGLE_MIRROR_CALENDAR_IDS=

# Email reservas (Gmail SMTP — contraseña de aplicación)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amsnowboardcoach@gmail.com
SMTP_PASS=
BOOKING_FROM_EMAIL=amsnowboardcoach@gmail.com
BOOKING_NOTIFY_EMAIL=amsnowboardcoach@gmail.com

# Clima
OPENWEATHER_API_KEY=

# Emails con rol coach al registrarse (separados por coma)
NEXT_PUBLIC_COACH_EMAILS=amsnowboardcoach@gmail.com

# UID del coach (alumnos se asignan a este coach)
NEXT_PUBLIC_DEFAULT_COACH_ID=

# URL pública (enlaces en emails al panel /coach)
NEXT_PUBLIC_APP_URL=https://am-snowboard-coach-green.vercel.app

# Firebase Console → Authentication → Sign-in method → habilitar "Anónimo"
# (visitantes pueden dar like y comentar en /tribu sin cuenta de alumno)

# WhatsApp del coach (solo dígitos, con prefijo país; opcional texto visible)
NEXT_PUBLIC_COACH_WHATSAPP=34617354031
NEXT_PUBLIC_COACH_WHATSAPP_DISPLAY=+34 617 354 031
# Aviso automático al coach cuando un alumno paga una reserva (ver docs/WHATSAPP_COACH_NOTIFY.md)
# COACH_WHATSAPP_NOTIFY_PHONE=34617354031
# CALLMEBOT_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886